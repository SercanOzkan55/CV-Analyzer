# CV Analyzer frontend — PRODUCTION build env (cvanalyzer.dev)
# Copy to frontend/.env.production before `npm run build`.

# Single-domain deploy: nginx proxies /api on the same origin, so leave empty.
# Only set this if the API lives on a separate domain (also update CSP).
VITE_API_BASE=

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_public_key

# Beta launch posture
VITE_PRIVATE_MODE=false
VITE_REGISTRATION_DISABLED=false
VITE_ENABLE_BLOG=false

# Comma-separated billing-admin emails (matches backend billing admin config)
VITE_BILLING_ADMIN_EMAILS=

# Optional override for the enterprise contact button
# VITE_CONTACT_SALES_URL=mailto:sales@cvanalyzer.dev
