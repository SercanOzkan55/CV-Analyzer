# Copy this file to .env and fill in your values
# Required for production deployment
VITE_API_BASE=https://your-backend.example.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_public_key
# Private mode: locks site behind login, disables registration
VITE_PRIVATE_MODE=false
# Disable registration independently (auto-enabled when PRIVATE_MODE=true)
VITE_REGISTRATION_DISABLED=false
