# Example environment file for cv-analyzer
# Copy this to `.env` and fill in real values before running the app.

# The database your application will use. In development you can run
# a local PostgreSQL instance (e.g. via Docker) and use a URL such as:
#
#   postgresql://postgres:password@localhost:5432/cvanalyzer
#
# Be careful not to point at a shared/production database such as
# Supabase's internal auth DB; doing so will expose you to accidental
# data loss. The code will warn if it detects "supabase.com" in the URL.
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/postgres?sslmode=require

# Supabase JWT settings (optional, used for authentication)
SUPABASE_URL=
SUPABASE_KEY=

# Toggles
MOCK_SERVICES=1        # 1 to turn on mock behaviour during tests
PORT=8001              # change if port conflicts arise

# SUPABASE JWT secret (used for local token verification)
SUPABASE_JWT_SECRET=

# Optional API URL override (frontend uses VITE_API_BASE)
API_URL=http://localhost:8001

# Rate limit values, weights, etc.
MODEL_WEIGHT=0.85
ATS_WEIGHT=0.15

# Sentry (optional) for error monitoring
# Set `SENTRY_DSN` in production/staging via secrets, not in VCS.
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.0
