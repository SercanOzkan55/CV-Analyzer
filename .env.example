# Example environment file for cv-analyzer
# Copy this to `.env` and fill in real values before running the app.

# The database your application will use. In development you can run
# a local PostgreSQL instance (e.g. via Docker) and use a URL such as:
#
#   postgresql://postgres:password@localhost:5432/cvanalyzer
#
# Be careful not to point at a shared/production database such as
# Supabase's internal auth DB; doing so will expose you to accidental
# data loss. The code will warn if it detects "supabase.com" in the URL.
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/postgres?sslmode=require

# Supabase JWT settings (optional, used for authentication)
SUPABASE_URL=
SUPABASE_KEY=

# Toggles
MOCK_SERVICES=1        # 1 to turn on mock behaviour during tests
PORT=8001              # change if port conflicts arise

# SUPABASE JWT secret (used for local token verification)
SUPABASE_JWT_SECRET=

# Optional API URL override (frontend uses VITE_API_BASE)
API_URL=http://localhost:8001

# Rate limit values, weights, etc.
MODEL_WEIGHT=0.85
ATS_WEIGHT=0.15
REDIS_FREE_DAILY_LIMIT=3
USER_FREE_DAILY=5
USER_PRO_DAILY=100
USER_ENTERPRISE_DAILY=1000
USER_FREE_MONTHLY=20
USER_PRO_MONTHLY=500
USER_ENTERPRISE_MONTHLY=5000
ORG_FREE_DAILY=50
ORG_PRO_DAILY=500
ORG_ENTERPRISE_DAILY=5000
ORG_FREE_MONTHLY=500
ORG_PRO_MONTHLY=5000
ORG_ENTERPRISE_MONTHLY=50000
RATE_LIMIT_IP_ANALYZE_PER_MIN=20
RATE_LIMIT_IP_ANALYZE_PDF_PER_MIN=20
RATE_LIMIT_USER_ANALYZE_PER_MIN=20
RATE_LIMIT_USER_ANALYZE_PDF_PER_MIN=20

# Stripe billing settings
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=test_secret
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/dashboard
CONTACT_SALES_EMAIL=sales@yourcompany.com
CRM_WEBHOOK_URL=
DEV_ALLOW_SELF_PREMIUM=1
AUTO_NEW_USER_PLAN=free
# Optional allow-lists for automatic premium assignment.
# Example: AUTO_PREMIUM_EMAILS=alice@example.com,bob@example.com
# Example: AUTO_PREMIUM_DOMAINS=mycompany.com,partner.org
AUTO_PREMIUM_EMAILS=
AUTO_PREMIUM_DOMAINS=

# Sentry (optional) for error monitoring
# Set `SENTRY_DSN` in production/staging via secrets, not in VCS.
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.0
