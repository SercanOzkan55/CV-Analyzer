# ============================================================
# CV Analyzer — Environment Variable Reference
# Copy this file to .env and fill in your values.
# ============================================================

# ── 1. DATABASE & AUTH ────────────────────────────────────────
DATABASE_URL=sqlite:///./cv_analyzer.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/cv_analyzer?sslmode=require
# DATABASE_URL_FILE=            # Docker secret file path (overrides DATABASE_URL)
ENV=development                 # development | production | test

SUPABASE_JWT_SECRET=            # HS256 secret for Supabase JWT verification
# SUPABASE_JWT_SECRET_FILE=     # Docker secret file path
SUPABASE_URL=                   # Supabase endpoint for JWKS (RS256/ES256)
SUPABASE_KEY=
WORKER_DOWNLOAD_SIGNING_SECRET= # Required in production for Local Worker TXT fallback signed URLs
WORKER_DOWNLOAD_URL_TTL_SECONDS=600 # Local Worker signed download URL TTL, 60-3600 seconds

# ── 2. OPENAI & ML MODELS ────────────────────────────────────
OPENAI_API_KEY=                 # Required for embeddings & AI features
ATS_MODEL_PATH=resume_model.pkl
HIRE_MODEL_PATH=hire_model.pkl
MODEL_PATH=resume_model.pkl     # Used by model_runner/worker
# MODEL_ONNX_PATH=model.onnx   # ONNX model (preferred over joblib)
# MODEL_SHA256=                 # Expected SHA256 hash for model integrity
ATS_CONFIG_PATH=ats_config.yaml

# ── 3. REDIS & CACHE ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=
REDIS_TIMEOUT_SECONDS=1.0
REDIS_PING_TIMEOUT_SECONDS=1.0
EMBEDDING_CACHE_TTL=604800      # 7 days
SCHEMA_VERSION=1
PARSER_VERSION=v1

# ── 4. AWS / S3 ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
S3_BUCKET=cv-analyzer-storage
STORAGE_BACKEND=s3              # s3 | local
# LOCAL_STORAGE_PATH=storage
# ALLOW_LOCAL_STORAGE_IN_PROD=0
AWS_USE_IAM_ROLE=0              # prod EC2/ECS/Lambda role kullanacaksan 1 yap
S3_SSE_ALGORITHM=AES256         # AES256 | aws:kms
# S3_KMS_KEY_ID=                # aws:kms kullanirken zorunlu

# ── 5. RATE LIMITING ─────────────────────────────────────────
IP_GLOBAL_LIMIT_PER_MIN=60
USER_GLOBAL_LIMIT_PER_MIN=30
USER_EMBED_LIMIT_PER_MIN=15
SEARCH_LIMIT_PER_MIN=30
MAX_SEARCH_QUERY_LEN=500
EMBED_MAX_CALLS_PER_MIN=60
EMBED_MAX_TOKENS_PER_REQ=8000
GLOBAL_CONCURRENCY_LIMIT=20
CONCURRENCY_ANALYZE=10
CONCURRENCY_ANALYZE_PDF=8
CONCURRENCY_CV_BUILDER=10
CONCURRENCY_REWRITE=5
CONCURRENCY_OPTIMIZE=5
CONCURRENCY_EMBED=6
REQUEST_QUEUE_SIZE=100
RATE_DICT_MAX_KEYS=10000
RATE_LIMIT_IP_ANALYZE_PER_MIN=20
RATE_LIMIT_IP_ANALYZE_PDF_PER_MIN=20
RATE_LIMIT_USER_ANALYZE_PER_MIN=20
RATE_LIMIT_USER_ANALYZE_PDF_PER_MIN=20

# ── 6. TIMEOUTS ──────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=120
TIMEOUT_ANALYZE=60
TIMEOUT_ANALYZE_PDF=60
TIMEOUT_ANALYZE_ASYNC=30
TIMEOUT_CV_BUILDER=90
TIMEOUT_REWRITE=60
TIMEOUT_OPTIMIZE=10
TIMEOUT_EMBED=30
TIMEOUT_SEARCH=15
MAX_UPLOAD_BYTES=5242880        # 5 MB per CV file
MAX_REQUEST_BODY_BYTES=6291456  # 6 MB multipart overhead included
MAX_RESPONSE_BODY_BYTES=52428800 # 50 MB
MAX_PDF_PAGES=50
MAX_PDF_OBJECTS=5000
MAX_DOCX_FILES=2000
MAX_DOCX_UNCOMPRESSED_BYTES=20971520
MAX_DOCX_COMPRESSION_RATIO=100
RECRUITER_MAX_BATCH_FILES=100
RECRUITER_LOCAL_MAX_BATCH_FILES=100
CV_RETENTION_DAYS=90
CV_RETENTION_BATCH_LIMIT=200
CV_VERSION_TEXT_STORAGE_MODE=full # full | metadata_only; metadata_only stores hashes instead of raw CV text

# ── 7. FEATURE FLAGS ─────────────────────────────────────────
# Each flag enables/disables the corresponding feature (1=on, 0=off).
FEATURE_OPTIMIZE=1              # CV optimization endpoint
FEATURE_AUTO_FIX=1              # Auto-fix CV service
FEATURE_SEMANTIC_SEARCH=1       # Semantic embedding-based search
FEATURE_HTML_EXPORT=1           # HTML export rendering
SAFE_MODE=0                     # Disable risky operations
MAINTENANCE_MODE=0              # Return 503 to all requests
ENABLE_CLASSIFIER=1             # Section classification module
ENABLE_AI_REVIEW=1              # AI-powered CV quality review
ENABLE_SANITIZER=1              # HTML sanitization in CV builder
ENABLE_FALLBACK=1               # Fallback parsing when primary fails
USE_SCHEMA_PIPELINE=1           # Schema-based CV pipeline (vs legacy)
MOCK_SERVICES=0                 # Mock implementations (dev/test only)
KILL_SWITCH=0                   # Emergency kill: disable all processing
MODEL_WORKER_DISABLED=0         # Disable background model worker
# LIVE_FLAGS_FILE=              # JSON file for dynamic flag overrides

# ── 8. QUOTAS & BILLING ──────────────────────────────────────
ENTITLE_FREE_DAILY_CV=3
ENTITLE_PRO_DAILY_CV=50
ENTITLE_ENTERPRISE_DAILY_CV=200
REDIS_FREE_DAILY_LIMIT=3
USER_FREE_DAILY=5
USER_PRO_DAILY=100
USER_ENTERPRISE_DAILY=1000
USER_FREE_MONTHLY=20
USER_PRO_MONTHLY=500
USER_ENTERPRISE_MONTHLY=5000
ORG_FREE_DAILY=50
ORG_PRO_DAILY=500
ORG_ENTERPRISE_DAILY=5000
ORG_FREE_MONTHLY=500
ORG_PRO_MONTHLY=5000
ORG_ENTERPRISE_MONTHLY=50000

# ── 9. STRIPE ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=test_secret
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/dashboard
CONTACT_SALES_EMAIL=sales@yourcompany.com
CRM_WEBHOOK_URL=
DEV_ALLOW_SELF_PREMIUM=0
AUTO_NEW_USER_PLAN=free
# AUTO_PREMIUM_EMAILS=alice@example.com,bob@example.com
# AUTO_PREMIUM_DOMAINS=mycompany.com,partner.org

# ── 10. SYSTEM & INFRASTRUCTURE ──────────────────────────────
PORT=8001
GUNICORN_BIND=0.0.0.0:8001
# GUNICORN_WORKERS=             # Defaults to CPU count
GUNICORN_TIMEOUT=30
GUNICORN_MAX_REQUESTS=1000
GUNICORN_LOG_LEVEL=info
LOG_DIR=/app/logs
LOG_MAX_BYTES=52428800          # 50 MB
LOG_BACKUP_COUNT=5
LOG_LEVEL=INFO
CPU_USAGE_LIMIT=90
MEMORY_RSS_LIMIT_MB=1024
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
# BACKUP_ENCRYPTION_PASSPHRASE= # Use secret manager / Docker secret, never commit
# BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=prod/db
# BACKUP_S3_KMS_KEY_ID=
BACKUP_S3_STORAGE_CLASS=STANDARD_IA
# INSTANCE_ID=                  # Auto-generated UUID if not set
BUILD_ID=dev
GIT_SHA=unknown
PARSER_BUILD=local
API_URL=http://localhost:8001

# ── 11. SECURITY & ABUSE PREVENTION ──────────────────────────
ADMIN_TOKEN=                    # Required for /admin/* and /metrics
BILLING_ADMIN_TOKEN=            # Required for billing admin page
TRUSTED_PROXY_COUNT=0
ADMIN_IP_ALLOWLIST=             # Optional CIDR/IP list for /admin/*, e.g. 203.0.113.10/32
ADMIN_RATE_LIMIT_PER_MIN=20
CSRF_PROTECTION_ENABLED=1       # Protect cookie-auth unsafe requests with X-CSRF-Token
# BLOCKED_IPS=                  # Comma-separated IPs to block
ABUSE_PROTECTION_ENABLED=1
ABUSE_SCORE_BLOCK_THRESHOLD=100
ABUSE_SCORE_AUDIT_THRESHOLD=60
ABUSE_BAN_SECONDS=900           # 15 minutes
ABUSE_FINGERPRINT_WINDOW_SECONDS=600
ABUSE_BURST_SOFT_LIMIT=20
ABUSE_BURST_HARD_LIMIT=40
ABUSE_BAN_DICT_MAX_ENTRIES=5000
ABUSE_COUNTER_MAX_ENTRIES=5000
THROTTLE_MAX_ENTRIES=10000
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN_SECONDS=30
ALERT_COOLDOWN_SECONDS=300
PANIC_ERROR_THRESHOLD=20
PANIC_ERROR_WINDOW=60
GUARD_SAFE_MODE_THRESHOLD=50
GUARD_SAFE_MODE_WINDOW=60
# CLAMAV_ENABLED=0
# CAPTCHA_ENABLED=0

# ── 12. SCORING WEIGHTS ──────────────────────────────────────
MODEL_WEIGHT=0.30               # ML model weight in final score
ATS_WEIGHT=0.70                 # Rule-based weight in final score
# Override ats_scoring.py category weights via env:
# ATS_WEIGHT_STRUCTURE=0.18
# ATS_WEIGHT_KEYWORDS=0.14
# ATS_WEIGHT_EXPERIENCE=0.18
# ATS_WEIGHT_EDUCATION=0.10
# ATS_WEIGHT_LANGUAGES=0.05
# ATS_WEIGHT_ATS=0.18
# ATS_WEIGHT_LENGTH=0.09
# ATS_WEIGHT_SOFT_SKILLS=0.08
# ── 15. OCR / CAMERA SCAN ──────────────────────────────────────
OCR_PROVIDER=auto             # auto | local | remote
OCR_SERVICE_URL=              # Remote OCR endpoint when Tesseract is unavailable
OCR_SERVICE_KEY=              # Optional API key for remote OCR service
# ── 13. SMTP / EMAIL ─────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=sikayet.cvanalizor@gmail.com
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=sikayet.cvanalizor@gmail.com
# REMINDER_EMAIL_FROM=sikayet.cvanalizor@gmail.com
# REMINDER_CHECK_INTERVAL_SECONDS=3600
# FEEDBACK_EMAIL_FROM=
# FEEDBACK_EMAIL_TO=
# SUPPORT_EMAIL=

# ── 14. MONITORING / OBSERVABILITY ───────────────────────────
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.0
REQUEST_SAMPLE_RATE=0.01
RL_LOG_INTERVAL_SECONDS=60
# DEBUG=0

# ── 15. CORS & LOCALIZATION ──────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_TIMEZONE=Europe/Istanbul
QUOTA_RESET_TIMEZONE=Europe/Istanbul

# ── 16. PARSING TUNING ───────────────────────────────────────
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=3
GLOBAL_PARSE_LIMIT=10
SLOW_CV_WARN_SECONDS=2
SLOW_CV_ABORT_SECONDS=5
# CV_ONE_PAGE_STRICT=0
AI_FINAL_REVIEW_ATS_THRESHOLD=60
MAX_WORKER_RESTARTS=3
WORKER_RESTART_DECAY_SECONDS=3600
