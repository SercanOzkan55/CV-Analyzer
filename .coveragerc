[run]
omit =
    */tests/*
    */__pycache__/*
    */.venv/*
    */venv/*
    */env/*
    */.env/*
    */migrations/*
    */scripts/*
    train_model.py
    add_recruiter.py
    check_env.py
    make_token.py
    manual_history_test.py
    remove_dupes.py
    reset_plans.py
    setup_db.py
    validate_saas.py
    locustfile.py
    # Downloadable client application; validated by dedicated local worker
    # tests, but excluded from the backend service coverage gate.
    local_worker/*
    # Non-unit runtime/deployment shims and generated scratch files.
    FEATURE_IMPLEMENTATIONS.py
    gunicorn_config.py
    # External provider adapters are integration-tested/stubbed in unit tests.
    services/domain_service.py
    services/embedding_service.py
    services/industry_service.py
    services/model_runner.py
    services/model_service.py
    services/model_worker.py
    # Optional document export backends require external binaries/fonts or
    # renderer-specific fixtures; keep them out of the global unit gate.
    renderers/docx_renderer.py
    renderers/pdf_renderer.py
    renderers/template_engine.py
    renderers/typst_renderer.py
    services/report_service.py

[report]
show_missing = True
skip_covered = True
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.
