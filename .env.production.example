# ============================================================
# CV Analyzer — PRODUCTION environment template (cvanalyzer.dev)
# Copy to .env on the production server and fill every empty value.
# Full knob reference lives in .env.example; this file lists only
# what production requires or overrides.
# Single-domain deploy: nginx serves the frontend and proxies /api
# to the backend (docker-compose.yml + nginx.conf).
# ============================================================

# ── CORE ──────────────────────────────────────────────────────
ENV=production
MOCK_SERVICES=0
SAFE_MODE=0
MAINTENANCE_MODE=0

# ── DATABASE (Supabase Postgres + pgvector) ───────────────────
# Use the Supabase pooler URL for the long-running web service. URL-encode any
# special characters in the password and keep sslmode=require.
DATABASE_URL=                     # REQUIRED — postgresql+psycopg2://...?...sslmode=require

# ── SUPABASE AUTH ─────────────────────────────────────────────
SUPABASE_URL=                     # https://<project-ref>.supabase.co
SUPABASE_KEY=                     # anon public key
SUPABASE_JWKS_URL=                # optional override: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_SECRET=            # legacy HS256 only; leave unset for ECC/P-256 JWT signing keys
# ALLOW_LEGACY_SUPABASE_HS_JWT=0

# ── REDIS (docker compose) ────────────────────────────────────
REDIS_PASSWORD=                   # REQUIRED — strong secret
# REDIS_URL is injected by docker-compose.prod.yml from REDIS_PASSWORD.

# ── OPENAI / MODELS ───────────────────────────────────────────
OPENAI_API_KEY=                   # REQUIRED for embeddings & AI features

# ── STORAGE (S3) ──────────────────────────────────────────────
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=                # REQUIRED unless AWS_USE_IAM_ROLE=1
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
S3_BUCKET=cv-analyzer-storage
S3_SSE_ALGORITHM=AES256

# ── SECURITY ──────────────────────────────────────────────────
ADMIN_TOKEN=                      # REQUIRED — /admin/* and /metrics
BILLING_ADMIN_TOKEN=              # REQUIRED — billing admin page
WORKER_DOWNLOAD_SIGNING_SECRET=   # REQUIRED in production
TRUSTED_PROXY_COUNT=1             # nginx sits in front of the app
CSRF_PROTECTION_ENABLED=1
ABUSE_PROTECTION_ENABLED=1

# ── DOMAIN / URLS (cvanalyzer.dev) ────────────────────────────
API_URL=https://cvanalyzer.dev
CORS_ORIGINS=https://cvanalyzer.dev,https://www.cvanalyzer.dev
OWNER_APP_URL=https://cvanalyzer.dev

# ── STRIPE (leave keys empty while payments are OFF for beta) ─
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_CHECKOUT_SUCCESS_URL=https://cvanalyzer.dev/billing/success
STRIPE_CHECKOUT_CANCEL_URL=https://cvanalyzer.dev/billing/cancel
STRIPE_BILLING_PORTAL_RETURN_URL=https://cvanalyzer.dev/dashboard
CONTACT_SALES_EMAIL=sales@cvanalyzer.dev

# ── EMAIL ─────────────────────────────────────────────────────
SUPPORT_EMAIL=support@cvanalyzer.dev
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=support@cvanalyzer.dev

# ── MONITORING ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=production
LOG_LEVEL=INFO
GUNICORN_WORKERS=2                # Safe starting point for the 2-vCPU / 8-GB VM
GUNICORN_TIMEOUT=150              # CV parsing can exceed the default 30-second timeout

# ── BUILD METADATA (set by deploy script/CI) ──────────────────
BUILD_ID=
GIT_SHA=
